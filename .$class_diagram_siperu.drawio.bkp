        <mxCell id="noteLaporan" value="Catatan: class Laporan pada diagram lama diganti menjadi ReportService karena kode tidak memiliki model Laporan." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
