        <mxCell id="noteJadwal" value="Catatan: JadwalRuangan ada sebagai model, tetapi belum dipakai oleh storage/service utama." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
