        </mxCell>
        <mxCell id="noteRelasiUml" value="Keterangan relasi UML: garis biasa = Association berbasis id_*; service ke JsonStorage = Aggregation karena service menyimpan referensi storage; Composition murni belum diterapkan pada domain model karena objek saling direferensikan lewat ID, bukan dimiliki sebagai atribut object." style="shape=note;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="1300" width="720" height="70" as="geometry" />
